{"id": "drb.3-john.1.11", "work": "douay-rheims", "citation": "3 John 1:11", "title": "", "path": ["New Testament", "3 John", "Chapter 1"], "type": "verse", "text": "Dearly beloved, follow not that which is evil: but that which is good. He that doth good is of God: he that doth evil hath not seen God.", "book": "3 John", "douay_book": "3 John", "chapter": 1, "verse": 11, "verse_key": "3-john/1/11", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}

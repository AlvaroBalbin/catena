{"id": "drb.philemon.1.1", "work": "douay-rheims", "citation": "Philemon 1:1", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Paul, a prisoner of Christ Jesus, and Timothy, a brother: to Philemon, our beloved and fellow labourer,", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 1, "verse_key": "philemon/1/1", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.2", "work": "douay-rheims", "citation": "Philemon 1:2", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "And to Appia, our dearest sister, and to Archippus, our fellow soldier, and to the church which is in thy house.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 2, "verse_key": "philemon/1/2", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.3", "work": "douay-rheims", "citation": "Philemon 1:3", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Grace to you and peace, from God our Father and from the Lord Jesus Christ.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 3, "verse_key": "philemon/1/3", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.4", "work": "douay-rheims", "citation": "Philemon 1:4", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "I give thanks to my God, always making a remembrance of thee in my prayers.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 4, "verse_key": "philemon/1/4", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.5", "work": "douay-rheims", "citation": "Philemon 1:5", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Hearing of thy charity and faith, which thou hast in the Lord Jesus and towards all the saints:", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 5, "verse_key": "philemon/1/5", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.6", "work": "douay-rheims", "citation": "Philemon 1:6", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "That the communication of thy faith may be made evident in the acknowledgment of every good work that is in you in Christ Jesus.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 6, "verse_key": "philemon/1/6", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.7", "work": "douay-rheims", "citation": "Philemon 1:7", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "For I have had great joy and consolation in thy charity, because the bowels of the saints have been refreshed by thee, brother.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 7, "verse_key": "philemon/1/7", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.8", "work": "douay-rheims", "citation": "Philemon 1:8", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Wherefore, though I have much confidence in Christ Jesus to command thee that which is to the purpose:", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 8, "verse_key": "philemon/1/8", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.9", "work": "douay-rheims", "citation": "Philemon 1:9", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "For charity sake I rather beseech, whereas thou art such a one, as Paul, an old man and now a prisoner also of Jesus Christ.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 9, "verse_key": "philemon/1/9", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.10", "work": "douay-rheims", "citation": "Philemon 1:10", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "I beseech thee for my son, whom I have begotten in my bands, Onesimus,", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 10, "verse_key": "philemon/1/10", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.11", "work": "douay-rheims", "citation": "Philemon 1:11", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Who hath been heretofore unprofitable to thee but now is profitable both to me and thee:", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 11, "verse_key": "philemon/1/11", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.12", "work": "douay-rheims", "citation": "Philemon 1:12", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Whom I have sent back to thee. And do thou receive him as my own bowels.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 12, "verse_key": "philemon/1/12", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.13", "work": "douay-rheims", "citation": "Philemon 1:13", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Whom I would have retained with me, that in thy stead he might have ministered to me in the bands of the gospel.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 13, "verse_key": "philemon/1/13", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.14", "work": "douay-rheims", "citation": "Philemon 1:14", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "But without thy counsel I would do nothing: that thy good deed might not be as it were of necessity, but voluntary.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 14, "verse_key": "philemon/1/14", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.15", "work": "douay-rheims", "citation": "Philemon 1:15", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "For perhaps he therefore departed for a season from thee that thou mightest receive him again for ever:", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 15, "verse_key": "philemon/1/15", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.16", "work": "douay-rheims", "citation": "Philemon 1:16", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Not now as a servant, but instead of a servant, a most dear brother, especially to me. But how much more to thee, both in the flesh and in the Lord?", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 16, "verse_key": "philemon/1/16", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.17", "work": "douay-rheims", "citation": "Philemon 1:17", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "If therefore thou count me a partner, receive him as myself.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 17, "verse_key": "philemon/1/17", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.18", "work": "douay-rheims", "citation": "Philemon 1:18", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "And if he hath wronged thee in any thing or is in thy debt, put that to my account.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 18, "verse_key": "philemon/1/18", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.19", "work": "douay-rheims", "citation": "Philemon 1:19", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "I Paul have written it with my own hand: I will repay it: not to say to thee that thou owest me thy own self also.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 19, "verse_key": "philemon/1/19", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.20", "work": "douay-rheims", "citation": "Philemon 1:20", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Yea, brother. May I enjoy thee in the Lord! Refresh my bowels in the Lord.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 20, "verse_key": "philemon/1/20", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
{"id": "drb.philemon.1.21", "work": "douay-rheims", "citation": "Philemon 1:21", "title": "", "path": ["New Testament", "Philemon", "Chapter 1"], "type": "verse", "text": "Trusting in thy obedience, I have written to thee: knowing that thou wilt also do more than I say.", "book": "Philemon", "douay_book": "Philemon", "chapter": 1, "verse": 21, "verse_key": "philemon/1/21", "segments": [], "citations_out": [], "source": {"edition": "Douay-Rheims, Challoner revision (1749-52)", "translator": "English College at Douay/Rheims; revised by Bishop Richard Challoner", "license": "public-domain", "url": "https://www.gutenberg.org/cache/epub/1581/pg1581.txt", "retrieved": "2026-07-09", "via": "Project Gutenberg eBook #1581"}}
